{
  "id": "esp32_finder",
  "name": "ESP32 Finder",
  "version": "0.1.0",
  "author": "GhostESP",
  "description": "Continuous WiFi OUI scanner with canvas dashboard and RGB blink.",
  "category": "Tools",
  "entry": "esp32_finder.so",
  "target": "esp32c5",
  "api_version": 1,
  "manifest_version": 1,
  "package_version": 1,
  "data_version": 1,
  "storage_scope": "app",
  "permissions": ["ui", "wifi", "rgb", "tasks"],
  "memory_limit": 32768,
  "stack_size": 4096,
  "requires_psram": false
}
