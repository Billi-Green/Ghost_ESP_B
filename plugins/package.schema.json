{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GhostESP Native SD App Manifest v1",
  "type": "object",
  "required": ["id", "name", "version", "entry", "target", "api_version"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "author": { "type": "string" },
    "description": { "type": "string" },
    "category": { "type": "string" },
    "entry": { "type": "string" },
    "target": { "type": "string" },
    "api_version": { "type": "integer", "const": 1 },
    "manifest_version": { "type": "integer", "const": 1 },
    "package_version": { "type": "integer", "minimum": 1 },
    "data_version": { "type": "integer", "minimum": 1 },
    "storage_scope": { "type": "string", "enum": ["app", "ghostesp"] },
    "permissions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "unsafe": { "type": "boolean" },
    "icon": { "type": "string" },
    "icon_width": { "type": "integer", "minimum": 1 },
    "icon_height": { "type": "integer", "minimum": 1 },
    "icon_format": { "type": "string", "enum": ["rgb565"] },
    "accent_color": { "type": "string", "pattern": "^#?[0-9A-Fa-f]{6}$" },
    "assets": {
      "type": "array",
      "items": { "type": "string" }
    },
    "memory_limit": { "type": "integer", "minimum": 0 },
    "stack_size": { "type": "integer", "minimum": 0 },
    "requires_psram": { "type": "boolean" },
    "checksum": { "type": "string" }
  }
}
